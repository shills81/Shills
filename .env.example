# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Alchemy API key for mainnet/testnet RPC
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Contract deployment config
DEPLOY_NAME="Lubies Factory Pass"
DEPLOY_SYMBOL=LFP
DEPLOY_MAX_SUPPLY=5000
DEPLOY_GENESIS_SUPPLY=100
DEPLOY_UNREVEALED_URI=ipfs://YOUR_UNREVEALED_METADATA_CID/
DEPLOY_ROYALTY_RECEIVER=0x0000000000000000000000000000000000000000
DEPLOY_ROYALTY_BPS=500

# Metadata generation config
METADATA_BASE_URI=ipfs://YOUR_METADATA_CID/
METADATA_IMAGE_BASE_URI=ipfs://YOUR_IMAGE_CID/
METADATA_ANIMATION_BASE_URI=ipfs://YOUR_SVG_CID/
METADATA_EXTERNAL_URL=https://lubies.xyz

# Generation output path
OUTPUT_DIR=./output

# Set to 'true' to enable gas reporting in tests
REPORT_GAS=false

# remove.bg API key — enables automatic subject outline extraction.
# Get your key at https://www.remove.bg/api
# Without this key, passes use duotone rendering (no cut-out outline).
REMOVE_BG_API_KEY=
